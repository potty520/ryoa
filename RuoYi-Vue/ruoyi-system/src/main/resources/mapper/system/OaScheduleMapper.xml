<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.OaScheduleMapper">

    <resultMap type="OaSchedule" id="OaScheduleResult">
        <result property="scheduleId"       column="schedule_id"       />
        <result property="scheduleTitle"   column="schedule_title"    />
        <result property="scheduleType"    column="schedule_type"     />
        <result property="startTime"        column="start_time"        />
        <result property="endTime"          column="end_time"          />
        <result property="scheduleContent" column="schedule_content"  />
        <result property="location"        column="location"          />
        <result property="remindFlag"     column="remind_flag"       />
        <result property="remindTime"      column="remind_time"       />
        <result property="status"           column="status"            />
        <result property="userId"          column="user_id"           />
        <result property="createBy"         column="create_by"         />
        <result property="createTime"      column="create_time"       />
        <result property="updateBy"        column="update_by"         />
        <result property="updateTime"      column="update_time"       />
        <result property="remark"           column="remark"            />
    </resultMap>

    <sql id="selectOaScheduleVo">
        select schedule_id, schedule_title, schedule_type, start_time, end_time,
               schedule_content, location, remind_flag, remind_time, status, user_id,
               create_by, create_time, update_by, update_time, remark
        from oa_schedule
    </sql>

    <select id="selectOaScheduleById" parameterType="Long" resultMap="OaScheduleResult">
        <include refid="selectOaScheduleVo"/>
        where schedule_id = #{scheduleId}
    </select>

    <select id="selectOaScheduleList" parameterType="OaSchedule" resultMap="OaScheduleResult">
        <include refid="selectOaScheduleVo"/>
        <where>
            <if test="scheduleTitle != null and scheduleTitle != ''">
                AND schedule_title like concat('%', #{scheduleTitle}, '%')
            </if>
            <if test="scheduleType != null and scheduleType != ''">
                AND schedule_type = #{scheduleType}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                AND start_time &gt;= #{params.beginTime}
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                AND start_time &lt;= #{params.endTime}
            </if>
        </where>
        order by start_time asc
    </select>

    <select id="selectUserScheduleList" resultMap="OaScheduleResult">
        <include refid="selectOaScheduleVo"/>
        <where>
            user_id = #{userId}
            AND status = '0'
            <if test="startTime != null and startTime != ''">
                AND start_time &gt;= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND end_time &lt;= #{endTime}
            </if>
        </where>
        order by start_time asc
    </select>

    <insert id="insertOaSchedule" parameterType="OaSchedule" useGeneratedKeys="true" keyProperty="scheduleId">
        insert into oa_schedule
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="scheduleTitle != null and scheduleTitle != ''">schedule_title,</if>
            <if test="scheduleType != null and scheduleType != ''">schedule_type,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="scheduleContent != null">schedule_content,</if>
            <if test="location != null and location != ''">location,</if>
            <if test="remindFlag != null">remind_flag,</if>
            <if test="remindTime != null">remind_time,</if>
            <if test="status != null">status,</if>
            <if test="userId != null">user_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="scheduleTitle != null and scheduleTitle != ''">#{scheduleTitle},</if>
            <if test="scheduleType != null and scheduleType != ''">#{scheduleType},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="scheduleContent != null">#{scheduleContent},</if>
            <if test="location != null and location != ''">#{location},</if>
            <if test="remindFlag != null">#{remindFlag},</if>
            <if test="remindTime != null">#{remindTime},</if>
            <if test="status != null">#{status},</if>
            <if test="userId != null">#{userId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateOaSchedule" parameterType="OaSchedule">
        update oa_schedule
        <set>
            <if test="scheduleTitle != null and scheduleTitle != ''">schedule_title = #{scheduleTitle},</if>
            <if test="scheduleType != null and scheduleType != ''">schedule_type = #{scheduleType},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="scheduleContent != null">schedule_content = #{scheduleContent},</if>
            <if test="location != null">location = #{location},</if>
            <if test="remindFlag != null">remind_flag = #{remindFlag},</if>
            <if test="remindTime != null">remind_time = #{remindTime},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where schedule_id = #{scheduleId}
    </update>

    <delete id="deleteOaScheduleById" parameterType="Long">
        delete from oa_schedule where schedule_id = #{scheduleId}
    </delete>

    <delete id="deleteOaScheduleByIds" parameterType="Long">
        delete from oa_schedule where schedule_id in
        <foreach item="scheduleId" collection="array" open="(" separator="," close=")">
            #{scheduleId}
        </foreach>
    </delete>

</mapper>
